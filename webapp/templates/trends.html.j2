{% extends "base.html.j2" %}
{% block body %}
<h1>傾向集計</h1>
<p class="muted">コース × ファクター別の過去成績（複勝率・単勝回収率）。Wilson 95% CI とサンプル数ゲート付き。</p>

<form class="card" method="get" action="/trends">
  <div class="grid">
    <label>コース
      <select name="course">
        {% for c in courses %}
        <option value="{{ c.track_code }}|{{ c.surface }}|{{ c.distance }}"
          {% if c.selected %}selected{% endif %}>
          {{ c.track_name }} {{ c.surface_label }}{{ c.distance }}m（{{ c.n_races }}R）
        </option>
        {% endfor %}
      </select>
    </label>
    <label>ファクター
      <select name="factor">
        {% for f in factors %}
        <option value="{{ f.key }}" {% if f.selected %}selected{% endif %}>{{ f.label }}</option>
        {% endfor %}
      </select>
    </label>
    <button type="submit">集計</button>
  </div>
</form>

{% if result %}
<div class="card">
  <strong>{{ result.track_name }} {{ result.surface_label }}{{ result.distance }}m ／ {{ result.factor_label }}</strong>
  <div class="muted">{{ result.from_date }}〜{{ result.to_date }} ・ 対象 {{ result.total }} 走 ・ min_n={{ result.min_n }}</div>
</div>
<div class="tablewrap">
<table>
  <thead><tr>
    <th>{{ result.factor_label }}</th><th class="num">出走</th><th class="num">勝率</th>
    <th class="num">複勝率</th><th>複勝率95%CI</th><th class="num">単回収</th>
  </tr></thead>
  <tbody>
  {% for c in result.cells %}
    <tr>
      <td>{% if c.color %}<span class="line-dot" style="background:{{ c.color }}"></span>{% endif %}{{ c.label }}</td>
      <td class="num">{{ c.n }}</td>
      <td class="num">{{ c.win_pct }}%</td>
      <td class="num">{{ c.top3_pct }}%</td>
      <td class="muted">{{ c.ci_lo }}–{{ c.ci_hi }}%</td>
      <td class="num" style="color:{{ 'var(--good)' if c.return_pct >= 100 else 'var(--muted)' }}">{{ c.return_pct }}%</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
</div>
{% if result.insufficient %}
<div class="insuf">サンプル不足（n&lt;{{ result.min_n }}・参考）:
  {% for c in result.insufficient %}{{ c.label }}(n={{ c.n }}){% if not loop.last %}, {% endif %}{% endfor %}
</div>
{% endif %}
<p class="muted" style="margin-top:10px;">複勝率は CI 幅を見て判断。回収率は控除率（約80%）超が妙味の目安。単期間の高回収は winner's curse に注意。</p>
{% endif %}
{% endblock %}
